{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Reflection": {
      "title": "Reflection",
      "description": "Daily reflection entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "audio"] },
        "emotion": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "response": {
          "type": "object",
          "properties": {
            "empathy_response": { "type": "string" },
            "mindfulness_activity": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "instruction": { "type": "string" }
              }
            }
          }
        }
      },
      "required": ["userId", "content", "type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reflections/{reflectionId}": {
      "schema": "Reflection",
      "description": "All user reflections"
    }
  }
}
